# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith (optional tracing)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=python-turborepo

# App settings
LOG_LEVEL=INFO
ENV=development
# Comma-separated allowed CORS origins (defaults to * in development)
ALLOWED_ORIGINS=https://your-frontend.com
